{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "s5d hook pretool-edit",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "s5d hook require-spec",
            "timeout": 10000,
            "type": "command"
          },
          {
            "command": "s5d hook pre-commit-validate",
            "timeout": 30000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "s5d hook user-prompt-submit",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ]
  }
}
